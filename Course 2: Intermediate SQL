#13. Select the title and release_year for all German-language films released before 2000
-----------------------------------------------------------------------
SELECT title, release_year
FROM films
WHERE language = 'German' AND release_year < 2000;


#14. Select all records for German-language films released after 2000 and before 2010
-----------------------------------------------------------------------------------
SELECT *
FROM films
WHERE language = 'German'
        AND  release_year > 2000 AND release_year < 2010;


#15. Find the title and year of films from the 1990 or 1999
-------------------------------------------------------
