#16. Find the title and year of films from the 1990 or 1999.
While restricting it English or Spanish only with gross more than 2000000
-------------------------------------------------------
SELECT title, release_year, gross
FROM films
WHERE (release_year = 1990 OR release_year = 1999)
	AND (language = 'English' OR language = 'Spanish')
	AND gross >2000000 ;

